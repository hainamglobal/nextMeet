{
  "_comment": "Sample SFU Configuration for Sae Video Conferencing - Add this to your site_config.json",
  
  "sfu_server_url": "http://localhost",
  "sfu_server_port": 3000,
  "sfu_api_key": "your-sfu-api-key-here",
  "sfu_secret": "your-sfu-secret-here",
  
  "sfu_timeout": 30,
  "sfu_reconnect_attempts": 5,
  "sfu_reconnect_delay": 1,
  "enable_sfu_logging": true,
  
  "turn_servers": [
    {
      "urls": "stun:stun.l.google.com:19302"
    },
    {
      "urls": "turn:your-turn-server.com:3478",
      "username": "turn-username",
      "credential": "turn-password"
    }
  ],
  
  "webrtc_config": {
    "iceServers": [
      {"urls": "stun:stun.l.google.com:19302"},
      {"urls": "stun:stun1.l.google.com:19302"}
    ],
    "iceCandidatePoolSize": 10,
    "bundlePolicy": "max-bundle",
    "rtcpMuxPolicy": "require"
  },
  
  "media_quality_presets": {
    "low": {
      "video": {
        "width": {"max": 640},
        "height": {"max": 480},
        "frameRate": {"max": 15}
      }
    },
    "medium": {
      "video": {
        "width": {"max": 1280},
        "height": {"max": 720},
        "frameRate": {"max": 30}
      }
    },
    "high": {
      "video": {
        "width": {"max": 1920},
        "height": {"max": 1080},
        "frameRate": {"max": 30}
      }
    }
  }
}
